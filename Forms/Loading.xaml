<Window x:Name="Login" x:Class="AstralService.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AstralService"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="750"
        MinHeight="350" MinWidth="400"
        MaxHeight="550" MaxWidth="800"
        Icon="/Assets/icon.ico"
        Background="Transparent"
        AllowsTransparency="True"
        WindowStyle="None"  
        ResizeMode="CanResize" WindowStartupLocation="CenterScreen"
        
        >
    <Grid>
        <Border CornerRadius="10">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#FF3A3A3A" Offset="0.0"/>
                    <GradientStop Color="#FF1C1C1C" Offset="1.0"/>
                </LinearGradientBrush>
            </Border.Background>

            <Grid>

                <Grid.RowDefinitions>
                    <RowDefinition Height="47*"/>
                    <RowDefinition Height="311*"/>
                    <RowDefinition Height="76*"/>
                    <RowDefinition Height="90*"/>
                </Grid.RowDefinitions>

                <Image Source="../Assets/logo.png"
                   Grid.Row="1"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center" Name="LogoImage" Height="378" Width="356"
                   />
                <TextBlock Grid.Row="1" Text="Loading" FontWeight="Bold" TextAlignment="Center"
                           FontSize="38" Foreground="White" Margin="0,267,0,10" Grid.RowSpan="2"
                           Opacity="0.0" Name="LoadingText"/>

            </Grid>

        </Border>
    </Grid>
</Window>
